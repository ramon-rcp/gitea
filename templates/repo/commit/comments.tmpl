{{range .comments}}

{{$createdStr:= DateUtils.TimeSince .CreatedUnix}}
<div class="comment" id="{{.HashTag}}">
	<div class="tw-mt-2 tw-mr-4">
		{{template "shared/user/avatarlink" dict "user" .Poster}}
	</div>
	<div class="content comment-container">
		<div class="comment-header avatar-content-left-arrow">
			<div class="comment-header-left">
				<span class="tw-text-text-light muted-links">
					{{template "shared/user/namelink" .Poster}}
					{{ctx.Locale.Tr "repo.issues.commented_at" .HashTag $createdStr}}
				</span>
			</div>
			<div class="comment-header-right">
				{{template "repo/commit/context_menu" dict "root" $.root "item" . "IsCommentPoster" (and $.root.IsSigned (eq $.root.SignedUserID .PosterID))}}
			</div>
		</div>
		<div class="ui attached segment comment-body">
			<div class="render-content markup" {{if or $.root.Permission.IsAdmin ($.root.Permission.CanWrite ctx.Consts.RepoUnitTypeCode) (and $.root.IsSigned (eq $.root.SignedUserID .PosterID))}}data-can-edit="true"{{end}}>
			{{if .RenderedContent}}
				{{.RenderedContent}}
			{{else}}
				<span class="no-content">{{ctx.Locale.Tr "repo.issues.no_content"}}</span>
			{{end}}
			</div>
			<div id="{{.HashTag}}-raw" class="raw-content tw-hidden">{{.Content}}</div>
			<div class="edit-content-zone tw-hidden" data-update-url="{{$.root.RepoLink}}/commit-comments/{{.ID}}" data-content-version="{{.ContentVersion}}" data-context="{{$.root.RepoLink}}" data-attachment-url="{{$.root.RepoLink}}/commit-comments/{{.ID}}/attachments"></div>
			{{if .Attachments}}
				{{template "repo/issue/view_content/attachments" dict "Attachments" .Attachments "RenderedContent" .RenderedContent}}
			{{end}}
		</div>
	</div>
</div>
{{end}}
